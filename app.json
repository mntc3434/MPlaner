{
  "expo": {
    "name": "MPlaner",
    "slug": "mplaner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android/mipmap-xxxhdpi/mplaner.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/android/mipmap-xxxhdpi/mplaner.png",
      "resizeMode": "contain",
      "backgroundColor": "#04070a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mplaner.app"
    },
    "android": {
      "package": "com.mplaner.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android/mipmap-xxxhdpi/mplaner.png",
        "backgroundColor": "#04070a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/android/mipmap-xxxhdpi/mplaner.png",
          "color": "#2ECC71"
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "expo-asset",
      "expo-mail-composer"
    ],
    "extra": {
      "eas": {
        "projectId": "7304993d-62a8-4e5b-bb07-6adb5c35594b"
      }
    }
  }
}
